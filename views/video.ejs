<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
        "http://www.w3.org/TR/html4/loose.dtd">
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>VOCS</title>
    <link rel="stylesheet" href="/css/index_css/style_index.css" type="text/css">
    <link rel="stylesheet" href="/css/vocs_styles.css" type="text/css">
    <!--Import Google Icon Font-->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <!--Import materialize.css-->
    <link type="text/css" rel="stylesheet" href="/css/index_css/index/materialize.css" media="screen,projection"/>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="js\index-scripts\materialize.js"></script>
    <script src="./components/jquery-ui-dist/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="/components/jquery-ui-dist/jquery-ui.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">

    <style>
        .tic{
            position: fixed;
            top: 40px;
            left: 20px;
            cursor: pointer;
            z-index: 100;
        }
        .ti {
            color: #3c7eff;
            padding: 10px;
            font-size: 1.2em;

        }
    </style>

</head>

<body>
<div class="tic">
    <span class="ti">i have accident</span>
    <span class="ti">i see an accident here</span>
    <span class="ti">i see a crash on the highway</span>
    <span class="ti">report an accident</span>
    <span class="ti">oh my god there is an accident</span>
    <span class="ti">i have problems</span>
    <span class="ti">Report traffic jam</span>
    <span class="ti">Report somthing</span>
    <span class="ti">here is a traffic jam</span>
    <span class="ti">I'm stuck in trakic</span>
    <span class="ti">vox</span>
    <span class="ti">I have to search for something</span>
    <span class="ti">32</span>
    <span class="ti">click accident</span>
    <span class="ti">click traffic</span>
    <span class="ti">click problems</span>
    <span class="ti">1</span>
    <span class="ti">stop</span>
</div>
<div id="canvas">
    <canvas class="visualizer"></canvas>
</div>
<div class="row row-margin">
    <div class="col-xs-12">
        <div id="controll-button">
            <button id="startRecord" type="button" class=" btn btn-default btn-circle btn-xl"><img id="control-img" src="./images/play_icon.svg"></button>
        </div>
    </div>
</div>
<!--Input field for testing ////////////////////////////////////////////////////////////////////////////////-->
<div class="row row-margin">
    <div class="col-xs-12 col-sm-8 col-sm-offset-2">
        <div class="form-group">
            <input class="form-control" type="text" placeholder="search">
        </div>
        <div class="row">
            <div class="col-xs-12 col-sm-4">
                <input class="btn btn-danger btn-block" type="button" data-placement="top"
                       data-toggle="popover" title="pressed"
                       data-content="" value="report an accident">
            </div>
            <div class="col-xs-12 col-sm-4">
                <input class="btn btn-primary btn-block" type="button" data-placement="top"
                       data-toggle="popover" title="pressed"
                       data-content="" value="report traffic">
            </div>
            <div class="col-xs-12 col-sm-4">
                <input class="btn btn-success btn-block" type="button" data-placement="top"
                       data-toggle="popover" title="pressed"
                       data-content="" value="another problem">
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-sx-12">
        <div class="vocs_ui_container">
            <div><img id="vocs_logo" src="./images/vocs_logo.svg"></div>
            <div class="vocs_ui_content">
                <!--<img id="vocs_state_icon" src="./images/mic_icon.svg"></div>-->
                <p id="vocs_text_status"></p>
                <p id="vocs_text_onrecognition"></p>
            </div>
        </div>
    </div>
</div>
<script>

    $(document).ready(function () {
        $('[data-toggle="popover"]').popover();
    });
</script>
<script src="/index.js" type="text/javascript"></script>
</BODY>

</HTML>
